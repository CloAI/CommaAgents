{
  "name": "@comma-agents/tui",
  "version": "2.0.0",
  "description": "Terminal UI for CommaAgents — connects to the daemon via WebSocket",
  "type": "module",
  "main": "src/index.tsx",
  "types": "src/index.tsx",
  "bin": {
    "comma-agents-tui": "src/main.tsx"
  },
  "scripts": {
    "start": "bun run src/main.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "generate:frames": "bun run src/components/TitleIcon/icon-generator/generator.ts",
    "test": "bun test --coverage"
  },
  "dependencies": {
    "@amandaghassaei/stl-parser": "1.7.0",
    "@comma-agents/core": "workspace:*",
    "@comma-agents/daemon": "workspace:*",
    "gl-matrix": "3.4.4",
    "ink": "5.1.0",
    "ink-select-input": "6.0.0",
    "ink-spinner": "5.0.0",
    "ink-text-input": "6.0.0",
    "react": "18.3.1",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@types/react": "18.3.18",
    "@types/yargs": "17.0.33",
    "typescript": "6.0.2"
  },
  "author": "CloAI",
  "license": "MIT"
}
