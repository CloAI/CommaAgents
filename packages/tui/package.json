{
  "name": "@comma-agents/tui",
  "version": "2.0.0",
  "description": "Terminal UI for CommaAgents — connects to the daemon via WebSocket",
  "type": "module",
  "main": "src/index.tsx",
  "types": "src/index.tsx",
  "bin": {
    "comma-agents-tui": "src/main.tsx"
  },
  "scripts": {
    "start": "bun --inspect-wait=127.0.0.1:6499/tui run src/main.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "generate:frames": "bun run src/components/TitleIcon/icon-generator/generator.ts",
    "test": "bun test --coverage",
    "lint": "bunx @biomejs/biome check src",
    "lint:fix": "bunx @biomejs/biome check --write src",
    "format": "bunx @biomejs/biome format --write src",
    "docs": "bun run --cwd docs dev",
    "docs:build": "bun run --cwd docs build"
  },
  "dependencies": {
    "@amandaghassaei/stl-parser": "1.7.0",
    "@comma-agents/core": "workspace:*",
    "@comma-agents/daemon": "workspace:*",
    "@shikijs/cli": "^4.0.2",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "gl-matrix": "3.4.4",
    "ink": "7.0.1",
    "ink-select-input": "6.2.0",
    "ink-spinner": "5.0.0",
    "ink-text-input": "6.0.0",
    "marked": "18.0.3",
    "react": "19.2.5",
    "react-router": "^7.14.2",
    "shiki": "4.0.2",
    "string-width": "8.2.0",
    "word-wrap": "1.2.5",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/yargs": "17.0.33",
    "ink-testing-library": "4.0.0",
    "typescript": "6.0.2"
  },
  "author": "CloAI",
  "license": "MIT"
}
