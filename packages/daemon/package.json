{
  "name": "@comma-agents/daemon",
  "version": "2.0.0-rc.0",
  "description": "Agent daemon that executes flows and exposes a WebSocket API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "bin": {
    "comma-agents-daemon": "dist/cli.js"
  },
  "scripts": {
    "start": "bun run src/cli.ts start --foreground",
    "build": "bun run ../../scripts/build-public-package.ts daemon",
    "prepack": "bun run build",
    "test": "bun test --coverage"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "2.0.30",
    "@comma-agents/core": "2.0.0-rc.0",
    "typescript": "6.0.2",
    "yaml": "2.7.0",
    "yargs": "17.7.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@comma-agents/utils": "file:../utils",
    "@types/yargs": "17.0.33",
    "ai": "6.0.91"
  },
  "engines": { "bun": ">=1.3.0" },
  "publishConfig": { "access": "public", "tag": "next" },
  "repository": {
    "type": "git",
    "url": "https://github.com/NateAGeek/commaagent2.git",
    "directory": "packages/daemon"
  },
  "author": "CloAI",
  "license": "MIT"
}
