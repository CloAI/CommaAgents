// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`built-in tool descriptions read_file description 1`] = `
"Read a workspace file and return its UTF-8 content plus a sha256 over the whole on-disk bytes for stale-file detection.

Inputs:
  - \`path\` (string, required) — Workspace-relative path to the file.
  - \`startLine\` (number, optional) — 1-indexed inclusive start line for slicing large files.
  - \`endLine\` (number, optional) — 1-indexed inclusive end line; clamped to the file's lineCount.
  - \`maxBytes\` (number, optional, default 262144) — Cap on the UTF-8 byte length of the returned slice; oversized slices set \`data.truncated\`.
  - \`allowBinary\` (boolean, optional, default false) — Opt in to reading binary content as base64. The first call on a binary file always returns \`binary_file\`.

Outputs (\`data\`):
  \`{ content?, contentBase64?, startLine, endLine, lineCount, sizeBytes, sha256, truncated, binary, newlineStyle, hasBom, encoding }\`. \`sha256\` always reflects the full file so it can be passed verbatim as \`expectedSha256\`.

Errors:
  - \`not_found\` — File missing, or path resolves to a directory — use \`list_directory\` instead.
  - \`outside_workspace\` — Path escapes the sandbox root or is absolute when not allowed.
  - \`permission_denied\` — Path matches a forbidden glob or is otherwise read-blocked by the sandbox.
  - \`binary_file\` — File is binary and \`allowBinary\` was not set. \`data.sizeBytes\` and \`data.sha256\` are still returned. Re-call with \`allowBinary: true\` to receive base64.

Notes:
  Slicing operates on LF-normalized content; \`sha256\` is computed on the raw bytes (BOM and CRLF preserved)."
`;

exports[`built-in tool descriptions list_directory description 1`] = `
"List the entries of a workspace directory and return both a structured array and a human-readable tree view.

Inputs:
  - \`path\` (string, required) — Workspace-relative directory to list. Use \`.\` for the workspace root.
  - \`recursive\` (boolean, optional, default false) — Walk subdirectories. Unbounded recursion is capped by \`maxDepth\`.
  - \`maxDepth\` (number, optional, default 8 when recursive, 1 otherwise (hard cap 32)) — Inclusive maximum depth relative to \`path\`.
  - \`includeHidden\` (boolean, optional, default false) — Include dot-prefixed entries (\`.git\`, \`.env\`, etc.).

Outputs (\`data\`):
  \`{ entries: [{ name, relativePath, type, size, mtime, depth }], truncated }\`.
  Entries are sorted by (depth asc, type [directory < file < symlink], name asc). Symlinks are reported with \`type: "symlink"\` and \`size: 0\` and are not followed. Results are capped at 5000 entries; \`truncated\` flags when the cap was hit.

Errors:
  - \`not_found\` — Path is missing or is not a directory.
  - \`outside_workspace\` — Path escapes the sandbox root or is absolute when not allowed.
  - \`permission_denied\` — Path is read-blocked by the sandbox (entries blocked by forbidden globs are filtered silently from successful listings).

Notes:
  Entries blocked by \`forbiddenGlobs\` or \`canRead\` are filtered silently — best-effort listing semantics."
`;

exports[`built-in tool descriptions search_files description 1`] = `
"Search the workspace by path glob, literal text, or regex; returns structured match locations with optional context lines.

Inputs:
  - \`query\` (string, required) — Pattern to match. Interpretation depends on \`mode\`: glob (path), literal (text), or JS regex (regex).
  - \`mode\` ("path" | "text" | "regex", required) — "path" matches file paths against a Bun.Glob; "text" searches file contents for a literal substring; "regex" compiles \`query\` as a JS regex with the "m" flag so ^/$ anchor on lines.
  - \`root\` (string, optional, default ".") — Workspace-relative directory to search under.
  - \`includeGlobs\` (string[], optional) — Path globs that candidate files must match.
  - \`excludeGlobs\` (string[], optional, default node_modules / .git / dist / build / .next / .turbo / coverage) — Path globs that candidates must NOT match.
  - \`maxResults\` (number, optional, default 100) — Cap on the number of matches; sets \`data.truncated\` when hit.
  - \`contextLines\` (number, optional, default 0) — Lines of surrounding context to include in each match's \`preview\`.

Outputs (\`data\`):
  \`{ matches: [{ path, line?, column?, preview }], truncated }\`. \`line\`/\`column\` are 1-indexed and omitted for \`path\` mode.

Errors:
  - \`not_found\` — \`root\` is missing or not a directory.
  - \`outside_workspace\` — \`root\` escapes the sandbox or is absolute when not allowed.
  - \`permission_denied\` — \`root\` is read-blocked by the sandbox.
  - \`command_failed\` — \`query\` is not a valid regex (regex mode only).

Notes:
  Binary files are skipped automatically in content modes. Files larger than 4194304 bytes are skipped. Traversal is capped at depth 32."
`;

exports[`built-in tool descriptions create_file description 1`] = `
"Create a brand-new file at \`path\` with the given UTF-8 content. Refuses to overwrite — use \`write_file\` for existing files.

Inputs:
  - \`path\` (string, required) — Workspace-relative path for the new file.
  - \`content\` (string, required) — UTF-8 content to write. Newline style of the input is preserved on disk.
  - \`createParentDirectories\` (boolean, optional, default false) — Create missing parent directories. When \`false\`, a missing parent returns \`not_found\`.

Outputs (\`data\`):
  \`{ created: true, sha256, diff }\` where \`diff\` is the unified diff from \`/dev/null\` to the new file. \`sha256\` can be reused as \`expectedSha256\` on a follow-up \`write_file\` / \`edit_file\` call.

Errors:
  - \`already_exists\` — A file already exists at \`path\` — call \`write_file\` with \`expectedSha256\` instead.
  - \`not_found\` — Parent directory missing and \`createParentDirectories\` is false.
  - \`outside_workspace\` — Path escapes the sandbox root or is absolute when not allowed.
  - \`permission_denied\` — Path is write-blocked by the sandbox or matches a forbidden glob.

Notes:
  Atomic write: content is staged to a tmp file in the same directory, fsync'd, then renamed into place.
  Every create is appended to the audit log as a \`create\` operation."
`;

exports[`built-in tool descriptions write_file description 1`] = `
"Replace the contents of an existing file. The sha256 from a prior \`read_file\` must be passed as \`expectedSha256\` so concurrent edits are detected.

Inputs:
  - \`path\` (string, required) — Workspace-relative path to the file. Must already exist.
  - \`content\` (string, required) — New UTF-8 content. The file's existing newline style and BOM are preserved automatically — pass plain LF text.
  - \`expectedSha256\` (string, required) — sha256 of the file as last read. Mismatch returns \`stale_file\` with the current hash in \`error.details\`.

Outputs (\`data\`):
  \`{ beforeSha256, afterSha256, diff }\`. \`afterSha256\` is the new on-disk hash for use as \`expectedSha256\` next time.

Errors:
  - \`not_found\` — File does not exist — use \`create_file\` instead.
  - \`stale_file\` — \`expectedSha256\` does not match the current on-disk hash. Re-read and retry.
  - \`binary_file\` — Existing file is binary — use \`apply_patch\` or a binary-aware workflow.
  - \`outside_workspace\` — Path escapes the sandbox root or is absolute when not allowed.
  - \`permission_denied\` — Path is write-blocked by the sandbox or matches a forbidden glob.

Notes:
  Atomic write: staged to a sibling tmp file, fsync'd, then renamed.
  Parent directories are NOT created — use \`create_file\` with \`createParentDirectories: true\` for new paths.
  Every write is appended to the audit log as an \`update\` operation."
`;

exports[`built-in tool descriptions edit_file description 1`] = `
"Apply one or more exact-string replacements to a text file in a single transaction.

All edits are matched against the ORIGINAL file snapshot, so edit order is irrelevant and earlier edits never create or hide matches for later edits.

Inputs:
  - \`path\` (string, required) — Workspace-relative path to an existing text file.
  - \`expectedSha256\` (string, required) — sha256 of the file as last read. Mismatch returns \`stale_file\`.
  - \`edits\` (Array<{ oldText, newText, expectedOccurrences? }>, required) — One or more replacement specs. \`expectedOccurrences\` defaults to 1 — any mismatch (zero or more than expected) is reported as a structured error rather than guessed.

Outputs (\`data\`):
  \`{ beforeSha256, afterSha256, appliedEdits: [{ editIndex, occurrences }], diff }\`. \`afterSha256\` is the new on-disk hash.

Errors:
  - \`not_found\` — File does not exist.
  - \`binary_file\` — Existing file is binary — use \`apply_patch\` for binary-adjacent workflows.
  - \`stale_file\` — \`expectedSha256\` does not match the current hash. Re-read and retry.
  - \`old_text_not_found\` — \`edits[i].oldText\` has zero matches. \`error.details.editIndex\` identifies which one.
  - \`multiple_matches\` — Match count does not equal \`expectedOccurrences\`. \`error.details.matchRanges: [{ startLine, endLine }]\` lists every match so you can narrow \`oldText\` or raise \`expectedOccurrences\`.
  - \`overlapping_edits\` — Two edits replace intersecting byte ranges in the original snapshot. \`error.details.conflictingEditIndices\` identifies the pair.
  - \`outside_workspace\` — Path escapes the sandbox root or is absolute when not allowed.
  - \`permission_denied\` — Path is write-blocked by the sandbox or matches a forbidden glob.

Examples:
  {"path":"a.ts","expectedSha256":"…","edits":[{"oldText":"foo","newText":"bar"}]} — single replacement, must match exactly once.
  {"path":"a.ts","expectedSha256":"…","edits":[{"oldText":"foo","newText":"bar","expectedOccurrences":3}]} — replace every of three known matches.

Notes:
  Atomic write: staged to a sibling tmp file, fsync'd, then renamed.
  Newline style and BOM of the existing file are preserved.
  Every successful run is appended to the audit log as an \`update\` operation."
`;

exports[`built-in tool descriptions delete_file description 1`] = `
"Delete a workspace file. By default the file is moved to a workspace-scoped trash bucket so it can be recovered.

Inputs:
  - \`path\` (string, required) — Workspace-relative path to a regular file. Directories are not deletable through this tool.
  - \`expectedSha256\` (string, required) — sha256 of the file as last read. Mismatch returns \`stale_file\`.
  - \`permanent\` (boolean, optional, default false) — Unlink directly without going through the trash. Not recoverable.

Outputs (\`data\`):
  \`{ deleted: true, beforeSha256, diff, trashedTo? }\`. \`trashedTo\` is set when the file went through the trash; \`diff\` is the unified diff from the file to \`/dev/null\`.

Errors:
  - \`not_found\` — File does not exist or is a directory.
  - \`stale_file\` — \`expectedSha256\` does not match the current hash. Re-read and retry.
  - \`outside_workspace\` — Path escapes the sandbox root or is absolute when not allowed.
  - \`permission_denied\` — Path is write-blocked by the sandbox or matches a forbidden glob.

Notes:
  Trash lives under \`<dataDir>/trash/<sha256(workspaceRoot)>/<timestamp>-<sessionId>-<runId>-<basename>.tar.gz\`. Archives are user-managed via the daemon (no automatic GC).
  Every delete is appended to the audit log as a \`delete\` operation."
`;

exports[`built-in tool descriptions move_file description 1`] = `
"Rename or move a regular file inside the workspace. Both paths must resolve inside the sandbox.

Inputs:
  - \`fromPath\` (string, required) — Workspace-relative path to the existing file.
  - \`toPath\` (string, required) — Workspace-relative destination path. Parent directory must already exist.
  - \`expectedSha256\` (string, required) — sha256 of \`fromPath\` as last read. Mismatch returns \`stale_file\`.
  - \`overwrite\` (boolean, optional, default false) — Allow overwriting an existing file at \`toPath\`. The overwritten file is moved to the trash first; never allowed when \`toPath\` is a directory.

Outputs (\`data\`):
  \`{ moved: true, sha256, overwroteTrashedTo? }\`. \`sha256\` is the post-move hash (re-verified) and equals \`expectedSha256\`.

Errors:
  - \`not_found\` — \`fromPath\` does not exist or is a directory; or \`toPath\`'s parent directory is missing.
  - \`already_exists\` — \`toPath\` exists and \`overwrite\` is not set, or \`toPath\` is a directory.
  - \`stale_file\` — \`expectedSha256\` does not match \`fromPath\`'s current hash.
  - \`outside_workspace\` — Either path escapes the sandbox root or is absolute when not allowed.
  - \`permission_denied\` — Either path is blocked by the sandbox or matches a forbidden glob.

Notes:
  Uses \`rename\` on the same device; falls back to copy + unlink across devices (EXDEV).
  Every move is appended to the audit log as a \`move\` operation."
`;

exports[`built-in tool descriptions apply_patch description 1`] = `
"Apply a multi-file patch in the OpenAI \`apply_patch\` v2 envelope format. A single call can Add, Update, Delete, and Move files together.

By default the whole patch is atomic: every change is staged, then committed by rename; any failure rolls back the files already committed.

Inputs:
  - \`patch\` (string, required) — Patch text bounded by \`*** Begin Patch\` / \`*** End Patch\`. See \`docs/patch-envelope.md\` for the grammar and worked examples.
  - \`expectedSha256ByPath\` (object<string, string>, optional) — Map of path → expected sha256 for Update / Delete / Move sources. Any mismatch fails the whole patch with \`stale_file\`.
  - \`atomic\` (boolean, optional, default true) — When \`true\`, no on-disk state changes until every hunk validates and stages cleanly. When \`false\`, files are applied sequentially and a failure leaves earlier changes in place.

Outputs (\`data\`):
  \`{ atomic, changedFiles: [{ path, operation, beforeSha256?, afterSha256?, diff }] }\`. \`operation\` is one of \`add\` / \`update\` / \`delete\` / \`move\`. For move operations \`path\` is the source and \`afterSha256\` reflects the new location.

Errors:
  - \`patch_parse_error\` — Patch text does not match the envelope grammar. \`error.details: { line, expected }\` points at the first offending line.
  - \`patch_apply_error\` — A hunk could not be applied with zero fuzz. \`error.details: { path, hunkIndex, reason }\` localizes the failure.
  - \`stale_file\` — An \`expectedSha256ByPath\` entry does not match the current on-disk hash.
  - \`not_found\` — An Update / Delete / Move source file is missing.
  - \`already_exists\` — An Add or Move destination already exists.
  - \`outside_workspace\` — A patched path escapes the sandbox root.
  - \`permission_denied\` — A patched path is blocked by the sandbox or matches a forbidden glob.

Notes:
  Each changed file is appended to the audit log with the matching operation kind.
  \`apply_patch\` is the preferred tool for any change touching more than one file — it gives atomicity that sequential \`write_file\` / \`edit_file\` calls can't."
`;

exports[`built-in tool descriptions run_command description 1`] = `
"Execute a shell command inside the workspace and capture its stdout, stderr, and exit code.

Host: Linux TEST (x64). Shell: /bin/sh -c. Runtime: bun TEST.

Pick commands that are valid on this host — POSIX utilities on macOS/Linux, \`cmd.exe\` syntax on Windows.

Inputs:
  - \`command\` (string, required) — Shell command line. Runs via the host shell shown above; pipes, redirects, and substitutions are supported.
  - \`cwd\` (string, optional, default workspace root) — Workspace-relative working directory. Must resolve inside the sandbox.
  - \`timeoutMs\` (number, optional, default 60000) — Kill the process (and its group on POSIX) after this many ms.
  - \`env\` (object<string, string>, optional) — Extra environment variables merged onto the parent environment (never replacing it).

Outputs (\`data\`):
  \`{ command, cwd, exitCode, signal, stdout, stderr, stdoutTruncated, stderrTruncated, timedOut, durationMs, platform }\`. Stdout/stderr are captured up to 1 MiB each; the \`*Truncated\` flags are set when content was dropped.

Errors:
  - \`outside_workspace\` — \`cwd\` escapes the workspace.
  - \`permission_denied\` — Command matches the deny list, or the user rejected an approval prompt for a high-risk pattern.
  - \`timeout\` — Exceeded \`timeoutMs\`. \`data.timedOut\` is true and partial stdout/stderr are preserved.
  - \`command_failed\` — Spawn failed (shell missing, etc.). A non-zero exit code is NOT an error: \`ok\` stays true and \`data.exitCode\` reflects the failure so you can inspect both output and status."
`;
