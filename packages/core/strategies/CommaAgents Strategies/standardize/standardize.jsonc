{
  "name": "Standardize",
  "version": "2.0",
  "description": "Recursive codebase auditor. A manager scouts the target the user names, picks the standards to enforce, and seeds a todo list of folders and files. A worker drains that list one todo at a time by *launching another strategy*: folder todos recursively launch `Standardize` itself on the child folder; file todos launch `Standardize File Audit` on the file. The supervisor stops the run when the list is empty.",
  "agents": {
    "user": {
      "type": "user",
      "description": "Collects the user's standardization request — what codebase to audit, which standards to enforce, any scope limits.",
      "config": {
        "requireInput": true
      }
    },

    "manager": {
      "description": "Scouts the codebase, resolves the standards, and seeds the shared todo list with one todo per top-level unit of work (a folder to recurse into or a file to audit).",
      "model": "openrouter/google/gemini-3.5-flash",
      "systemPrompt": "./prompts/standards-manager.md",
      "tools": [
        "read_file",
        "list_directory",
        "glob",
        "search_files",
        "list_skills",
        "load_skill",
        "ask_question",
        "todo_add",
        "todo_get"
      ]
    },

    "worker": {
      "description": "Drains the shared todo list one unit at a time by launching the right sub-strategy: `Standardize` for folder todos (recursive), `Standardize File Audit` for file todos. Each launch runs synchronously to completion; its returned text is the evidence used to complete or block the todo.",
      "model": "openrouter/google/gemma-4-31b-it",
      "systemPrompt": "./prompts/standards-worker.md",
      "tools": [
        "list_strategy",
        "launch_strategy",
        "todo_get",
        "todo_get_next",
        "todo_complete",
        "todo_add"
      ]
    },

    "supervisor": {
      "description": "Cycle observer. Reads the shared todo list after each Worker iteration and decides whether to keep dispatching or stop.",
      "model": "openrouter/google/gemma-4-31b-it",
      "systemPrompt": "./prompts/standards-cycle-observer.md",
      "tools": [
        "todo_get",
        "load_skill"
      ]
    },

    "summarizer": {
      "description": "Produces the final human-facing report after the dispatch cycle ends.",
      "model": "openrouter/google/gemma-4-31b-it",
      "systemPrompt": "./prompts/standards-summarizer.md",
      "tools": [
        "todo_get"
      ]
    }
  },

  "flow": {
    "name": "Standardize Flow",
    "type": "sequential",
    "description": "User (or parent worker) describes the target → manager seeds the todo list → worker dispatches each todo via launch_strategy (folder → Standardize recursive; file → Standardize File Audit) under the supervisor's watch → summarizer reports.",
    "steps": [
      { "agent": "user" },
      { "agent": "manager" },
      {
        "name": "Dispatch Drain Loop",
        "type": "cycle",
        "cycles": "Infinity",
        "observer": "supervisor",
        "description": "Worker pops one todo per iteration and launches the matching sub-strategy. Folder todos recurse into Standardize; file todos launch Standardize File Audit. The supervisor emits DONE when the todo list is empty.",
        "steps": [
          { "agent": "worker" }
        ]
      },
      { "agent": "summarizer" }
    ]
  }
}
