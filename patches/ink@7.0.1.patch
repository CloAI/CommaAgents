+import type { ReactNode } from 'react';
+export type MeasureLayoutOptions = {
+    /**
+     * The available width (in columns) within which the tree should lay out.
+     * Required — Yoga needs a definite constraint to resolve percent and
+     * flex-grow values.
+     */
+    readonly width: number;
+    /**
+     * Optional height constraint. When omitted, the tree lays out at its
+     * intrinsic height (yoga returns the natural content height).
+     */
+    readonly height?: number;
+};
+export type MeasureLayoutResult = {
+    readonly width: number;
+    readonly height: number;
+};
+/**
+ * Measure the layout dimensions of a React element synchronously, without
+ * writing to any terminal stream or starting a persistent Ink instance.
+ *
+ * See `measure-layout.js` for the full documentation.
+ */
+declare const measureLayout: (node: ReactNode, options: MeasureLayoutOptions) => MeasureLayoutResult;
+export default measureLayout;
