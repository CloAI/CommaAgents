{
  "name": "comma-agents",
  "private": true,
  "version": "2.0.0",
  "description": "Composable agent orchestration framework",
  "workspaces": [
    "packages/*",
    "examples",
    "end-to-end-tests"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "test:e2e": "bun test end-to-end-tests/",
    "lint": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write .",
    "format": "bunx @biomejs/biome format --write .",
    "knip": "knip",
    "daemon": "bun run --filter @comma-agents/daemon start",
    "tui": "bun run --filter @comma-agents/tui start",
    "example": "bun run examples/core/strategies/run.ts",
    "example:tui": "bun run --cwd examples tui",
    "docs": "bun run --cwd docs dev",
    "docs:build": "bun run --cwd docs build"
  },
  "author": "CloAI",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "bun-types": "1.3.9",
    "knip": "6.0.5"
  }
}
